# Git
.git
.gitignore

# Environnements et secrets - JAMAIS dans l'image
.env
.env.local
.env.*.local
.env.prod
.env.test

# Cache / logs locaux (regeneres dans le conteneur)
var/cache/*
var/log/*
!var/cache/.gitkeep
!var/log/.gitkeep

# Fichiers Docker eux-memes (inutiles dans l'image)
docker-compose*.yml

# Dependances locales (reinstallees par composer install dans le build)
vendor/
node_modules/

# Tests et documentation
tests/
README.md
*.md

# IDE
.idea/
.vscode/