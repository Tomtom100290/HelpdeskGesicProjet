{% extends 'base.html.twig' %}

{% block title %}Logiciels
{% endblock %}

{% block body %}
	<div class="navbar">
		<a href="{{ path('app_ticket_index') }}" class="group inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold rounded-xl transition-all duration-200" style="color: #7c5cbf; background-color: #7c5cbf1a;" onmouseover="this.style.backgroundColor='#7c5cbf2e'" onmouseout="this.style.backgroundColor='#7c5cbf1a'">
			<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1" fill="none" viewbox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
			</svg>
			Retour
		</a>
		<h1>Logiciels</h1>
	</div>
	<div class="BlocLogiciel">

		<a class="takeit" href="{{ path('app_logiciel_new') }}" style="display: flex; align-items: center; gap: 6px; color: white; text-decoration: none;">
			<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 640 640" width="24" height="24" fill="white">
				<path d="M352 128C352 110.3 337.7 96 320 96C302.3 96 288 110.3 288 128L288 288L128 288C110.3 288 96 302.3 96 320C96 337.7 110.3 352 128 352L288 352L288 512C288 529.7 302.3 544 320 544C337.7 544 352 529.7 352 512L352 352L512 352C529.7 352 544 337.7 544 320C544 302.3 529.7 288 512 288L352 288L352 128z"/>
			</svg>
			Nouveau logiciel
		</a>

		<div id="logiciels-container">
			{% if logiciels is empty %}
				<p class="text-gray-400 empty-message">Aucun logiciel trouvé</p>
			{% endif %}

			{% for logiciel in logiciels %}
				<div class="cardLogiciels">
					<div class="head">
						<div class="clientId">
							#{{ logiciel.id }}</div>
						<p class="priority ">{{ logiciel.typeLogiciel }}</p>
					</div>

					<div class="ticket-body">
						<h3>{{ logiciel.libelle }}</h3>
						<p class="descripTicket">{{ logiciel.description }}</p>
					</div>

					<div class="foot">

						<div class="actions">
							<a href="{{ path('app_logiciel_show', {'id': logiciel.id}) }}" class="card-link">Voir</a>
							<a href="{{ path('app_logiciel_edit', {'id': logiciel.id}) }}" class="card-link">Éditer</a>
						</div>
					</div>


				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}
