{% extends 'base.html.twig' %}

{% block title %}Logiciels déployés
{% endblock %}

{% block body %}
	<h1>Logiciel</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ logiciel.id }}</td>
			</tr>
			<tr>
				<th>Libelle</th>
				<td>{{ logiciel.libelle }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ logiciel.description }}</td>
			</tr>
			<tr>
				<th>TypeLogiciel</th>
				<td>{{ logiciel.typeLogiciel }}</td>
			</tr>
			<tr>
				<th>CoeffCriticite</th>
				<td>{{ logiciel.coeffCriticite }}</td>
			</tr>
			<tr>
				<th>TopActif</th>
				<td>{{ logiciel.topActif ? 'Yes' : 'No' }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_logiciel_index') }}">retour</a>

	<a href="{{ path('app_logiciel_edit', {'id': logiciel.id}) }}">editer</a>

	{{ include('logiciel/_delete_form.html.twig') }}
{% endblock %}
