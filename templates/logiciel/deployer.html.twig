{% extends 'base.html.twig' %}

{% block title %}Déploiement de Logiciels
{% endblock %}

{% block body %}
	<div class="container mx-auto my-8 p-6 max-w-4xl bg-white shadow-md rounded-lg">

		<h1 class="text-2xl font-bold text-gray-800 mb-6 border-b pb-3">
			🚀 Déployer une version de logiciel
		</h1>

		{# Affichage des messages flash de succès ou d'erreur #}
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="mb-4 p-4 rounded text-white {{ label == 'success' ? 'bg-green-500' : 'bg-red-500' }}">
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}

		{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

		{# Ligne 1 : Choix du logiciel et de la Version #}
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
			<div>
				{{ form_label(form.logiciel, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
				{{ form_widget(form.logiciel, {'attr': {'class': 'w-full border-gray-300 rounded-md shadow-sm'}}) }}
				{{ form_errors(form.logiciel) }}
			</div>
			<div>
				{{ form_label(form.version, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
				{{ form_widget(form.version, {'attr': {'class': 'w-full border-gray-300 rounded-md shadow-sm'}}) }}
				{{ form_errors(form.version) }}
			</div>
		</div>

		{# Ligne 2 : Sélection des Clients (En grille de cases à cocher) #}
		<div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
			<h2 class="text-sm font-semibold text-gray-700 mb-3">
				{{ form_label(form.clients) }}
			</h2>

			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
				{% for child in form.clients %}
					<label class="flex items-center space-x-3 bg-white p-3 rounded-md border border-gray-300 shadow-sm cursor-pointer hover:bg-indigo-50 transition">
						{{ form_widget(child, {'attr': {'class': 'h-4 w-4 text-indigo-600 border-gray-300 rounded'}}) }}
						<span class="text-sm text-gray-900 font-medium">
							{{ child.vars.label }}
						</span>
					</label>
				{% endfor %}
			</div>
			{{ form_errors(form.clients) }}
		</div>

		{# Boutons d'action #}
		<div class="flex justify-end space-x-3 pt-4 border-t">
			<a href="#" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
				Annuler
			</a>
			<button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md text-sm font-medium shadow-sm transition">
				Confirmer l'installation
			</button>
		</div>

		{{ form_end(form) }}
	</div>
{% endblock %}
