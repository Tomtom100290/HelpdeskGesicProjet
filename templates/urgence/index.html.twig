{% extends 'base.html.twig' %}

{% block title %}Urgence index{% endblock %}

{% block body %}
    <h1>Urgence index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Niveau</th>
                <th>Libelle</th>
                <th>Prompt</th>
                <th>Note</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for urgence in urgences %}
            <tr>
                <td>{{ urgence.id }}</td>
                <td>{{ urgence.niveau }}</td>
                <td>{{ urgence.libelle }}</td>
                <td>{{ urgence.prompt }}</td>
                <td>{{ urgence.note }}</td>
                <td>
                    <a href="{{ path('app_urgence_show', {'id': urgence.id}) }}">show</a>
                    <a href="{{ path('app_urgence_edit', {'id': urgence.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_urgence_new') }}">Create new</a>
{% endblock %}
