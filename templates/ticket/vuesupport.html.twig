{% extends 'base.html.twig' %}

{% block title %}Liste des tickets
{% endblock %}

{% block body %}
	<div class="navbar">

		<h1>Espace Support</h1>
	</div>
	<div class="bg-gray-50 py-8 px-4" style="box-sizing: border-box; overflow: hidden;">


		<div
			class="indexSupport">

			{# ── Nouveaux tickets ── #}
			<div class="BlocTickets">
				<h2>Nouveaux tickets</h2>
				<a class="takeit" href="{{ path('app_ticket_new') }}" style="display: flex; align-items: center; gap: 6px; color: white; text-decoration: none;">
					<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 640 640" width="24" height="24" fill="white">
						<path d="M352 128C352 110.3 337.7 96 320 96C302.3 96 288 110.3 288 128L288 288L128 288C110.3 288 96 302.3 96 320C96 337.7 110.3 352 128 352L288 352L288 512C288 529.7 302.3 544 320 544C337.7 544 352 529.7 352 512L352 352L512 352C529.7 352 544 337.7 544 320C544 302.3 529.7 288 512 288L352 288L352 128z"/>
					</svg>
					Nouveau ticket
				</a>
				<div id="tickets-container">
					{% if nouveauxtickets is empty %}
						<p class="text-gray-400 empty-message">Aucun ticket trouvé</p>
					{% endif %}

					{% for nouveauxticket in nouveauxtickets %}
						<div class="card" data-ticket-id="{{ nouveauxticket.id }}">
							<div class="head">
								<div class="clientId">#{{ nouveauxticket.id }}</div>
								<p class="priority">{{ nouveauxticket.libellePriorite }}</p>
							</div>

							<div class="ticket-body">
								<h3>{{ nouveauxticket.titre }}</h3>
								<p class="descripTicket">{{ nouveauxticket.description }}</p>
							</div>

							<div class="foot">
								<div class="datecreat">
									{{ nouveauxticket.dateCreation|date('d/m/Y') }}
								</div>
								<div class="actions">
									<a href="{{ path('app_ticket_show', {'id': nouveauxticket.id}) }}" class="card-link">Voir</a>
									<a href="{{ path('app_ticket_edit', {'id': nouveauxticket.id}) }}" class="card-link">Éditer</a>
								</div>
							</div>

							<div id="statut-{{ nouveauxticket.id }}" class="status">
								<span class="libstatus {{ nouveauxticket.statut.color() }}">
									{{ nouveauxticket.statut.label() }}
								</span>
								{% if nouveauxticket.statut.value == 'nouveau' %}
									<button data-action="prendre-en-charge" data-id="{{ nouveauxticket.id }}" class="takeit">
										Prendre en charge
									</button>
								{% endif %}
							</div>
						</div>
					{% endfor %}
				</div>
			</div>

			{# ── Mes tickets en cours ── #}
			<div class="BlocTickets">
				<h2>Mes Tickets "en cours"</h2>
				<div id="mestickets-container">
					{% if ticketsassignes is empty %}
						<p class="text-gray-400 empty-message">Aucun ticket trouvé</p>
					{% endif %}

					{% for ticketsassigne in ticketsassignes %}
						<div class="card" data-ticket-id="{{ ticketsassigne.id }}">
							<div class="head">
								<div class="clientId">#{{ ticketsassigne.id }}</div>
								<p class="priority">{{ ticketsassigne.libellePriorite }}</p>
							</div>

							<div class="ticket-body">
								<h3>{{ ticketsassigne.titre }}</h3>
								<p class="descripTicket">{{ ticketsassigne.description }}</p>
							</div>

							<div class="foot">
								<div class="datecreat">
									{{ ticketsassigne.dateCreation|date('d/m/Y') }}
								</div>
								<div class="actions">
									<a href="{{ path('app_ticket_show', {'id': ticketsassigne.id}) }}" class="card-link">Voir</a>
									<a href="{{ path('app_ticket_edit', {'id': ticketsassigne.id}) }}" class="card-link">Éditer</a>
								</div>
							</div>

							<div id="statut-{{ ticketsassigne.id }}" class="status">
								<span class="libstatus {{ ticketsassigne.statut.color() }}">
									{{ ticketsassigne.statut.label() }}
								</span>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>

			{# ── Charge de l'équipe ── #}
			<div class="BlocEquipe">
				<h2>Charge de l'Équipe</h2>
				<div id="equipe-container">

					{% for developpeur in developpeurs %}
						{% set ticketsEnCours = developpeur.ticketsAssignes|filter(t => t.statut.value == 'en_cours') %}
						{% set nbTickets = ticketsEnCours|length %}
						{% set pourcentage = nbTickets >= 10 ? 100 : (nbTickets * 10) %}

						<div class="personnel">
							<a href="{{ path('details_ticket_utilisateur', { id: developpeur.id }) }}">
								<div class="détailsCharge">
									<wa-icon name="eye" variant="regular" style="color: rgb(61, 51, 51);"></wa-icon>Voir détails
								</div>
							</a>
							<div class="idpersonnel">

								<div class="imgUtilisateur"></div>
								<div class="infoMessage">
									<strong>{{ developpeur.prenom }}
										{{ developpeur.nom }}</strong>
								</div>
								{# ── Barre de charge ── #}
								<div class="flex items-center justify-between mb-1 mt-2">
									<span class="text-xs text-white w-30">Charge de travail</span>
									<span class="text-xs font-bold text-white mr-2">{{ pourcentage }}%</span>
								</div>
								<div class="w-full  bg-gray-300 border border-gray-300 rounded-full h-2 mb-2 ">
									<div class="h-2 rounded-full transition-all duration-500" style="width: {{ pourcentage }}%; background: {% if pourcentage < 50 %}var(--vert){% elseif pourcentage < 80 %}orange{% else %}#ef4444{% endif %};"></div>
								</div>
								<p class="text-xs text-white mb-1 ml-4">{{ nbTickets }}
									tickets</p>
							</div>

							<div
								class="donnéesCharge">


								{# ── Liste des tickets ── #}
								<div class="listeTickets">
									{% for ticket in ticketsEnCours %}
										<div>#{{ ticket.id }}
											-
											{{ ticket.titre }}</div>
									{% endfor %}
								</div>

							</div>
						</div>
					{% endfor %}

				</div>
			</div>

		</div>
	</div>

	<script>
		(function () { // Ferme l'ancienne connexion si elle existe
if (window._mercureEs) {
window._mercureEs.close();
}

const currentUserId = {{ app.user.id }};

const STATUTS = {
{% for statut in statuts %}
'{{ statut.value }}' : {
label: '{{ statut.label() }}',
css: '{{ statut.color() }}'
},{% endfor %}
};

const hubUrl = new URL('http://127.0.0.1:3000/.well-known/mercure');
hubUrl.searchParams.append('topic', 'ticket/liste');

window._mercureEs = new EventSource(hubUrl);
const es = window._mercureEs;

es.onerror = () => console.error("Mercure erreur", es.readyState);

es.onmessage = (e) => {
const data = JSON.parse(e.data);
console.log('Mercure reçu:', data);

if (data.statut === 'en_cours') { // 1. Supprimer la carte du bloc "Nouveaux tickets"
const cardNouveau = document.querySelector (`#tickets-container [data-ticket-id="${
data.id
}"]`);
if (cardNouveau) {
cardNouveau.style.opacity = "0";
cardNouveau.style.transition = "all 0.4s ease";
setTimeout(() => cardNouveau.remove(), 400);
}

// 2. Si c'est MOI → ajouter dans "Mes tickets"
if (parseInt(data.assigneId) === parseInt(currentUserId)) {
const colonneMesTickets = document.getElementById('mestickets-container');
const emptyMsg = colonneMesTickets.querySelector('.empty-message');
if (emptyMsg) 
emptyMsg.remove();



const nouvelleCard = document.createElement('div');
nouvelleCard.className = 'card';
nouvelleCard.dataset.ticketId = data.id;
nouvelleCard.style.opacity = "0";
nouvelleCard.style.transition = "all 0.4s ease";
nouvelleCard.innerHTML = `
                    <div class="head">
                        <div class="clientId">#${
data.id
}</div>
                    </div>
                    <div id="statut-${
data.id
}" class="status">
                        <span class="libstatus ${
STATUTS['en_cours'] ?. css ?? ''
}">
                            ${
STATUTS['en_cours'] ?. label ?? 'En cours'
}
                        </span>
                    </div>
                `;

colonneMesTickets.prepend(nouvelleCard);
setTimeout(() => {
nouvelleCard.style.opacity = "1";
nouvelleCard.style.transform = "scale(1.03)";
setTimeout(() => nouvelleCard.style.transform = "", 300);
}, 50);
}

// 3. Mettre à jour la carte dans "Charge de l'équipe"
const cardEquipe = document.querySelector (`#equipe-container [data-ticket-id="${
data.id
}"]`);
if (cardEquipe) {
const statutDiv = document.getElementById (`statut-${
data.id
}`);
if (statutDiv) {
const info = STATUTS[data.statut] ?? {
label: data.statut,
css: 'bg-gray-100 text-gray-600'
};
statutDiv.innerHTML = `
                        <span class="libstatus ${
info.css
}">
                            ${
info.label
}${
data.assigne ? ' — ' + data.assigne : ''
}
                        </span>
                    `;
}
const btn = cardEquipe.querySelector('[data-action="prendre-en-charge"]');
if (btn) 
btn.remove();



}
}
};

document.addEventListener('click', async (e) => {
const btn = e.target.closest('[data-action="prendre-en-charge"]');
if (! btn) 
return;



btn.disabled = true;
btn.textContent = "En cours...";

await fetch (`/ticket/${
btn.dataset.id
}/prendre-en-charge`, {method: 'POST'});
});

})();
	</script>
{% endblock %}
