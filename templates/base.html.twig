<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<!-- Dans ton <head> -->
		<link rel="stylesheet" href="path/to/web-awesome.css"/>
		<script type="module" src="path/to/web-awesome.js"></script>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('styles/app.css') }}">
		{% endblock %}

		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

		{% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
		{% if frankenphpHotReload %}
			<meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
			<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
			<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
			<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"></script>
		{% endif %}
	</head>
	<body>
		<main class="flex w-full ">
			<aside class="min-w-[180px] w-[20%] top-0 left-0 text-white p-4 rounded-tr-xl rounded-br-xl shadow-lg shadow-black/20">
				<nav
					class="space-y-2">
					<!--Récupération de l'utilisateur-->
					<div class="UtilisateurID">
						<div class="imgUtilisateur"></div>
						{% if app.user %}
							<p>Bonjour,
								{{ app.user.prenom }}
								{{ app.user.nom }}
								!</p>

							<p id="mailrole">
								{{ app.user.email }}
								-
								{{ app.user.role.label() }}</p>

							<a href="{{ path('app_logout') }}">Se déconnecter</a>
						{% else %}
							<a href="{{ path('app_login') }}">Se Connecter</a>
						{% endif %}
					</div>
					<!--FIN Récupération de l'utilisateur-->

					<!--Affichage HORLOGE-->
					<div class="horloge">{% include 'horloge/afficheheure.html.twig' %}</div>

					<!--Liens de navigation-->
					<h3>Navigation</h3>
					<div class="liens flex flex-col gap-1">


						<a href="{{ path('app_ticket_index') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-200">
								<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
								<polyline points="9 22 9 12 15 12 15 22"/>
							</svg>
							Accueil
						</a>

						<a href="{{ path('app_ticket_new') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-200">
								<path d="M12 5v14M5 12h14"/>
							</svg>
							Nouveau ticket
						</a>

						<div class="h-[1px] bg-white/10 my-3 mx-3"></div>

						<h3>Paramètres avancés</h3>

						<a href="{{ path('app_logiciel_index') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-purple-100 hover:text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-300/80">
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
								<line x1="8" y1="21" x2="16" y2="21"/>
								<line x1="12" y1="17" x2="12" y2="21"/>
							</svg>
							Logiciel
						</a>

						<a href="{{ path('app_logiciel_client_index') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-purple-100 hover:text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-300/80">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
								<circle cx="9" cy="7" r="4"/>
								<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
								<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
							</svg>
							Logiciel Client
						</a>

						<a href="{{ path('app_client_index') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-purple-100 hover:text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-300/80">
								<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
								<polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
								<line x1="12" y1="22.08" x2="12" y2="12"/>
							</svg>
							Client
						</a>

						<a href="{{ path('app_utilisateur_index') }}" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-purple-100 hover:text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-300/80">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
								<circle cx="12" cy="7" r="4"/>
							</svg>
							Utilisateur
						</a>

						<a href="" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/10 transition text-sm text-purple-100 hover:text-white decoration-none">
							<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-300/80">
								<polyline points="12 8 12 12 14 14"/>
								<path d="M3.05 11a9 9 0 1 1 .5 4m-.5 5v-5h5"/>
							</svg>
							Historique
						</a>
					</div>

					<!--Séparateur-->
					<div class="w-[90%] h-[2px] bg-gray-400 my-[16px]"></div>

					<!--stats-->
					<div class="stats mx-auto">
						<div class="start-1 h-[150px] w-[150px] rounded-xl bg-amber-200 mt-[16px] flex flex-col justify-center items-center mx-auto">
							<h3 class="text-black text-center text-2xl">Tickets<br>ouvert</h3>
							<p class="text-black text-center text-4xl font-bold mt-2">10</p>
						</div>
						<div class="start-2 h-[150px] w-[150px] rounded-xl bg-green-100 mt-[16px] flex flex-col justify-center items-center mx-auto">
							<h3 class="text-black text-center text-2xl">Tickets<br>en cours</h3>
							<p class="text-black text-center text-4xl font-bold mt-2">4</p>
						</div>
					</div>
				</nav>
			</aside>

			<div class="flex-1"> {% block body %}{% endblock %}
				</div>
			</main>
		</body>
	</html>
