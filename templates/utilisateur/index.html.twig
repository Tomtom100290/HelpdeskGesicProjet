{% extends 'base.html.twig' %}

{% block title %}Utilisateur index{% endblock %}

{% block body %}
<aside class="fixed top-0 left-0 h-screen w-64 bg-gray-900 text-white p-4">
    <nav class="space-y-2">
        <a href="/" class="block p-2 hover:bg-gray-700 rounded">Home</a>
        <a href="/events" class="block p-2 hover:bg-gray-700 rounded">Events</a>
        <a href="/orders" class="block p-2 hover:bg-gray-700 rounded">Orders</a>
        <a href="/settings" class="block p-2 hover:bg-gray-700 rounded">Settings</a>
    </nav>
</aside>
    <h1>Utilisateur index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Email</th>
                <th>Entreprise</th>
                <th>Role</th>
                <th>DateCreation</th>
                <th>TopActif</th>
                <th>NumTel</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for utilisateur in utilisateurs %}
            <tr>
                <td>{{ utilisateur.id }}</td>
                <td>{{ utilisateur.nom }}</td>
                <td>{{ utilisateur.prenom }}</td>
                <td>{{ utilisateur.email }}</td>
                <td>{{ utilisateur.entreprise }}</td>
                <td>{{ utilisateur.role.label }}</td>
                <td>{{ utilisateur.dateCreation ? utilisateur.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ utilisateur.topActif ? 'Yes' : 'No' }}</td>
                <td>{{ utilisateur.numTel }}</td>
                <td>
                    <a href="{{ path('app_utilisateur_show', {'id': utilisateur.id}) }}">show</a>
                    <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_utilisateur_new') }}">Create new</a>
{% endblock %}
