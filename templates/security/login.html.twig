{% extends 'base.htmlLight.twig' %}

{% block title %}Connexion - NEXUS -
{% endblock %}

{% block body %}
	<main class="PageLight">
		<div class="ConnexionContainter">
			<div class="logo-container">
				<img src="{{ asset('images/logo-version-white.png') }}" alt="Logo-Nexus" class="logo">

			</div>

			<span class="text-white text-center">Bienvenue sur NEXUS,
			</br>votre outil de gestion de tickets.</span>
		<form method="post">
			{% if error %}
				<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
			{% endif %}

			{% if app.user %}
				<div class="mb-3">
					Vous êtes connecté en tant que
					{{ app.user.userIdentifier }},
					<a href="{{ logout_path() }}">Se déconnecter</a>
				</div>
			{% endif %}


			<h1 id="Seconnecter">Connexion</h1>
			<label for="username">Email</label>
			<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
			<label for="password">Password</label>
			<input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
			<input
			type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

			{#
																																																																																																																	            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
																																																																																																																	            See https://symfony.com/doc/current/security/remember_me.html
																																																																																																																	
																																																																																																																	            <div class="checkbox mb-3">
																																																																																																																	                <input type="checkbox" name="_remember_me" id="_remember_me">
																																																																																																																	                <label for="_remember_me">Remember me</label>
																																																																																																																	            </div>
																																																																																																																	        #}

			<button class="takeit" type="submit">
				Se connecter
			</button>
		</form>
	</div>
</main>{% endblock %}
